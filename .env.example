# Supabase Configuration
# You can find these credentials in your Supabase Dashboard -> Project Settings -> API
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# AIMLAPI Configuration
# Get your API key from https://aimlapi.com/ dashboard
AIMLAPI_API_KEY="your-aimlapi-api-key"
AIMLAPI_BASE_URL="https://api.aimlapi.com/images/generations"
AIMLAPI_MODEL="flux/schnell"

# FastAPI Server Setup
ENVIRONMENT="development"
PORT=8000
